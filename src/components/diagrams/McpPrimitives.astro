---
// The three MCP server primitives and who controls each.
---
<svg class="dgm" viewBox="0 0 680 156" role="img" aria-label="The three MCP primitives: Tools are model-controlled actions, Resources are app-controlled data, Prompts are user-invoked templates.">
  <!-- Tools -->
  <rect x="14" y="16" width="206" height="128" rx="8" class="dgm-box" />
  <text x="36" y="52" class="dgm-title">Tools</text>
  <text x="36" y="80" class="dgm-sub dgm-sub--accent">model-controlled</text>
  <text x="36" y="106" class="dgm-label">actions the model</text>
  <text x="36" y="124" class="dgm-label">chooses to call</text>

  <!-- Resources -->
  <rect x="237" y="16" width="206" height="128" rx="8" class="dgm-box" />
  <text x="259" y="52" class="dgm-title">Resources</text>
  <text x="259" y="80" class="dgm-sub dgm-sub--accent">app-controlled</text>
  <text x="259" y="106" class="dgm-label">read-only data,</text>
  <text x="259" y="124" class="dgm-label">addressed by URI</text>

  <!-- Prompts -->
  <rect x="460" y="16" width="206" height="128" rx="8" class="dgm-box" />
  <text x="482" y="52" class="dgm-title">Prompts</text>
  <text x="482" y="80" class="dgm-sub dgm-sub--accent">user-invoked</text>
  <text x="482" y="106" class="dgm-label">reusable, parameterised</text>
  <text x="482" y="124" class="dgm-label">templates</text>
</svg>
