---
// LSM read path: check the memtable, then walk SSTables newest-first.
// A Bloom filter skips most SSTables without touching the disk.
---
<svg class="dgm" viewBox="0 0 680 190" role="img" aria-label="LSM read path: check the memtable, then SSTables newest first. A Bloom filter answers 'no' for most SSTables so their disk blocks are never read; a 'maybe' triggers a real block read.">
  <defs>
    <marker id="lr-ah" viewBox="0 0 10 10" refX="8.5" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
      <path d="M0,0 L10,5 L0,10 z" class="dgm-arrow" />
    </marker>
  </defs>

  <rect x="12" y="66" width="98" height="46" rx="8" class="dgm-box" />
  <text x="61" y="94" text-anchor="middle" class="dgm-label">get(k)</text>
  <line x1="110" y1="89" x2="134" y2="89" class="dgm-line" marker-end="url(#lr-ah)" />

  <rect x="136" y="63" width="120" height="52" rx="8" class="dgm-box" />
  <text x="154" y="90" class="dgm-title">Memtable</text>
  <text x="154" y="107" class="dgm-sub">miss</text>
  <line x1="256" y1="89" x2="288" y2="89" class="dgm-line" marker-end="url(#lr-ah)" />

  <rect x="290" y="54" width="150" height="76" rx="8" class="dgm-box" />
  <text x="306" y="82" class="dgm-label">SSTable</text>
  <text x="306" y="102" class="dgm-sub">Bloom: no</text>
  <text x="306" y="119" class="dgm-sub">skip disk</text>
  <line x1="440" y1="92" x2="474" y2="92" class="dgm-line dgm-line--accent" marker-end="url(#lr-ah)" />

  <rect x="476" y="54" width="192" height="76" rx="8" class="dgm-box dgm-box--accent" />
  <text x="494" y="82" class="dgm-label">SSTable</text>
  <text x="494" y="102" class="dgm-sub dgm-sub--accent">Bloom: maybe</text>
  <text x="494" y="119" class="dgm-sub">read block · found</text>
</svg>
