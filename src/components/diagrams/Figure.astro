---
interface Props {
  caption?: string;
  label?: string;
}
const { caption, label } = Astro.props;
---

<figure class="figure">
  <div class="figure__frame">
    <slot />
  </div>
  {caption && (
    <figcaption class="figure__cap">
      {label && <span class="figure__label">{label}</span>}
      {caption}
    </figcaption>
  )}
</figure>
