---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { formatDate, pad } from '../../utils';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Writing" description="Long-form technical writing on storage engines, LLM infrastructure, agents, and building things that hold up in production.">
  <div class="wrap">
    <section class="hero" style="padding-block: 3.5rem 1rem;">
      <p class="label hero__eyebrow rise rise-1">The writing</p>
      <h1 class="rise rise-2">Writing</h1>
      <p class="hero__lede rise rise-3" style="margin-top:1rem;">
        Deep dives on systems and AI, the kind of thing I wish existed when I was
        figuring it out. Mostly evergreen, occasionally opinionated.
      </p>
    </section>

    <section class="section rise rise-4" style="border-top:0; padding-top:0;">
      <ul class="entries">
        {posts.map((p, i) => (
          <li class="entry">
            <span class="entry__no">{pad(posts.length - i)}</span>
            <a href={`/writing/${p.id}/`} class="entry__title">{p.data.title}</a>
            <div class="entry__meta">
              <time datetime={p.data.date.toISOString()}>{formatDate(p.data.date)}</time>
              {p.data.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
            <p class="entry__desc">{p.data.description}</p>
          </li>
        ))}
        {posts.length === 0 && <li class="muted" style="padding:1rem 0;">No posts yet.</li>}
      </ul>
    </section>
  </div>
</Base>
