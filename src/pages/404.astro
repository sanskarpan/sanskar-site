---
import Base from '../layouts/Base.astro';
---

<Base title="Not found" description="This page has wandered off.">
  <div class="wrap">
    <section class="hero" style="text-align:center; padding-block: 6rem 4rem;">
      <p class="label hero__eyebrow rise rise-1" style="justify-content:center;">Error 404</p>
      <h1 class="rise rise-2" style="margin-inline:auto;">This page slipped out of the ledger.</h1>
      <p class="hero__lede rise rise-3" style="margin-inline:auto;">
        Nothing lives at this path. Head back to <a href="/">the front page</a> or
        browse <a href="/writing">the writing</a>.
      </p>
    </section>
  </div>
</Base>
