---
import Base from './Base.astro';
import { formatDate } from '../utils';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  minutes?: number;
  backHref?: string;
  backLabel?: string;
}
const {
  title, description, date, updated, tags = [], minutes,
  backHref = '/writing', backLabel = 'writing',
} = Astro.props;
---

<Base title={title} description={description} type="article">
  <article class="wrap" style="max-width: 46rem;">
    <header class="article__head rise rise-1">
      <a href={backHref} class="backlink">← {backLabel}</a>
      <h1>{title}</h1>
      <p class="article__desc">{description}</p>
      <div class="article__meta">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        {minutes && <><span class="dot">·</span><span>{minutes} min read</span></>}
        {updated && <><span class="dot">·</span><span>updated {formatDate(updated)}</span></>}
        {tags.map((t) => <span class="tag">{t}</span>)}
      </div>
    </header>

    <div class="prose rise rise-2">
      <slot />
    </div>

    <hr style="border:0; border-top:1px solid var(--line); margin: 3rem 0 1.5rem;" />
    <a href={backHref} class="backlink">← back to {backLabel}</a>
  </article>
</Base>
